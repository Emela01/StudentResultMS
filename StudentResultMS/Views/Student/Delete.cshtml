@{
}

@model StudentResultMS.Models.Student

<h2 class="mb-3 text-danger">Delete Student</h2>

<h4>Are you sure you want to delete this student?</h4>

<div class="mb-3">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Matric No:</strong> @Model.MatricNo</p>
    <p><strong>Course:</strong> @Model.Department</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>
