@{
}

@model StudentResultMS.Models.Course

<h2 class="mb-3">Add Course</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">Course Name</label>
        <input asp-for="CourseName" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Course Code</label>
        <input asp-for="CourseCode" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Unit</label>
        <input asp-for="Units" class="form-control" type="number" min="1" />
    </div>

    <button type="submit" class="btn btn-success">
        Save
    </button>

</form>
