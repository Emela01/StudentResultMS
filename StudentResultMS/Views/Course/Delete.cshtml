@{
}

@model StudentResultMS.Models.Course

<h2 class="mb-3 text-danger">Delete Course</h2>

<h4>Are you sure you want to delete this course?</h4>

<div class="mb-3">
    <p><strong>Course Name:</strong> @Model.CourseName</p>
    <p><strong>Course Code:</strong> @Model.CourseCode</p>
    <p><strong>Unit:</strong> @Model.Units</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>