@{
}

@model StudentResultMS.Models.Result

<h2 class="mb-3">Delete Result</h2>

<h4>Are you sure you want to delete this result?</h4>

<div class="card mt-3">
    <div class="card-body">
        <p><strong>Student:</strong> @Model.Student.Name</p>
        <p><strong>Course:</strong> @Model.Course.CourseName</p>
        <p><strong>Score:</strong> @Model.Score</p>
        <p><strong>Grade:</strong> @Model.Grade</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>